{
  "name": "paul999/downloadpage",
  "type": "phpbb-extension",
  "description": "Download page for phpBB.nl.",
  "homepage": "https://www.phpbb.nl",
  "version": "1.0.0-dev",
  "keywords": ["phpbb"],
  "license": "GPL-2.0",
  "authors": [
    {
      "name": "Paul Sohier",
      "email": "paul@phpbb.nl"
    }
  ],
  "require": {
    "php": "~7 | ~8",
    "composer/installers": "~1.0 | ~v2.3.0"
  },
  "require-dev": {
    "phing/phing": "2.4.*"
  },
  "extra": {
    "display-name": "Download page",
    "soft-require": {
      "phpbb/phpbb": ">=3.2.0,<3.4.0@dev"
    }
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true
    }
  }
}
